---
// src/pages/index.astro
import { getCollection, getEntry } from 'astro:content';

// Fetch the publication data
const sortedPublications = (await getCollection('publications')).sort(
  (a, b) => b.data.year - a.data.year,
);

const coauthors = (await getCollection('coauthors'));

const name = "Alesya Raevskaya (Esya)";
const myAuthorName = "Alesya Raevskaya";

const today = new Date();
const lastUpdated = today.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="google-site-verification" content="bVJ73wRzUzaAZQFjMb_ntGH8E01JKrNRuhlRR4DHqM4" />
	<meta name="description" content="Personal portfolio of Alesya Raevskaya (Esya), a PhD researcher specializing in Distributed Algorithms" />
	<link rel="icon" type="image/png" href="/logo3.png" />
    <title>{name}</title>
  </head>
  <body>
    <header class="hero">
      <h1>{name}</h1>
      <p class="subtitle">PhD Student in Computer Science at <a href="https://www.aalto.fi/en" class="university">Aalto university</a></p>
      
      <p class="contact-text">Email: name dot surname at aalto dot fi</p>

      <nav class="nav-links">
        <a href="#about">About</a>
        <a href="#publications">Publications</a>
        <a href="#teaching">Teaching</a>
        <a href="#service">Activities</a>
        <a href="/CV.pdf">CV</a>
      </nav>
    </header>

    <main>
      <section id="about" class="section">
        <h2>About Me</h2>
        <p class="bio-text">
          I am a PhD researcher at <a href={"https://research.cs.aalto.fi/da/"} class="link">Distributed Algorithms group</a>. I am mostly interested in complexity theory in the field of Distributed Algorithms. 
        </p>
      </section>

      <section id="publications" class="section">
        <h2>Publications</h2>
        <div class="pub-list">
          {sortedPublications.map((pub) => (
            <article class="pub-card">
              <span class="pub-year">{pub.data.year}</span>
              <div class="pub-content">
                <h3 class="pub-title">{pub.data.title}</h3>
                <p>
                      {pub.data.authors.map((authorR, index) => {
                    
                    const coauthor = coauthors.find(
                      (author) => author.data.id === authorR
                    );
                    const isMe = authorR === myAuthorName; 
                    return (
                      <>
                        {coauthor ? (
                          <a href={coauthor.data.url} class="author-link" target="_blank">{authorR}</a>
                        ) : isMe ? (
                          <span class="author-me">{authorR}</span>
                        ) : (
                          <span class="pub-authors">{authorR}</span>
                        )}
                        {index < pub.data.authors.length - 1 ? ", " : ""}
                      </>
                    );
                      })}
                  </p>
                <p class="pub-venue">
                  {pub.data.venue}
                </p>
                <div class="pub-links">
                  {pub.data.pdfLink && <a href={pub.data.pdfLink} class="btn-link">[PDF]</a>}
                  {pub.data.codeLink && <a href={pub.data.codeLink} class="btn-link">[Code]</a>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

	  <section id="teaching" class="section">
        <h2>Teaching</h2>
		    <ul>
            <li>
              <p  class="service-text"> Teaching assistant for Distributed Algorithms </p>
              <p  class="service-place"> Aalto University, Espoo, Finland </p></li>
            <li>
              <p  class="service-text"> Developer for Programming Parallel Computers </p>
              <p  class="service-place"> Aalto University, Espoo, Finland </p></li>
            <li>
              <p  class="service-text"> Teaching assistant for Principles of Algorithmic Techniques </p>
              <p  class="service-place"> Aalto University, Espoo, Finland </p></li>
            <li>
              <p  class="service-text"> Teaching assistant for Calculus & Advanced Calculus </p>
              <p  class="service-place"> HSE, Moscow, Russia </p></li>
            <li>
              <p  class="service-text"> Teaching assistant for Algorithms and Data Structures </p>
              <p  class="service-place"> HSE, Moscow, Russia </p></li>
        </ul>
      </section>

      <section id="service" class="section">
        <h2>Activities & Service</h2>
		    <ul>
            <li>
              <p  class="service-text"> Organiser of <a href={"https://algorithms.fi/puzzle-and-pizza/"} class="hidden-link">Puzzle & Pizza</a></p>
            </li>
			      <li>
              <p  class="service-text"> Reviewer for <a href={"https://www.disc-conference.org/wp/disc2026/"} class="hidden-link">DISC 2026</a></p>
            </li>
        </ul>
      </section>
    </main>
  </body>
  <footer class="site-footer">
    <p>Last updated: {lastUpdated}</p>
  </footer>
</html>

<style>
  /* Modern CSS Reset & Variable setup */
  :root {
    --bg-color: #fafafa;
    --text-main: #1f2937;
    --text-muted: #4b5563;
	  --text-more-muted: #797a7d;
    --extra-accent: #eb25db;
    --accent: #2563eb;
    --accent-hover: #1d4ed8;
    --border-color: #e5e7eb;
    --card-bg: #ffffff;
  }

  html {
	font-size: 16px;
  }

  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background-image: url("/background4.png");
    background-repeat: repeat;
    color: var(--text-main);
    line-height: 1.6;
    max-width: 1000px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  /* Header / Hero Styling */
  .hero h1 {
    font-size: 4rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.75rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .university {
    font-weight: 600;
    color: var(--text-main);
    text-decoration: none;
  }

  .university:hover {
    font-weight: 600;
    color: var(--accent-hover);
    text-decoration: none;
  }

  .nav-links a {
    color: var(--text-more-muted);
    text-decoration: none;
    margin-right: 1.5rem;
    font-weight: 500;
    transition: color 0.2s ease;
	  font-size: 1.5rem;
  }

  .nav-links a:hover {
    color: var(--accent);
  }

  /* Structural Sections */
  .section {
    margin-top: 3.5rem;
  }

  .section h2 {
    font-size: 2rem;
    font-weight: 700;
    border-bottom: 3px solid var(--border-color);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  /* Contact info */
  .contact-text {
    font-size: 1.5rem;
    color: var(--extra-accent);
    font-weight: 300;
    margin-bottom: 3.5rem; /* Pushes the 'About Me' section down to give the header room */
  }

  /* Bio section */
  .bio-text {
	font-size: 1.5rem;
	color: var(--text-main);
	line-height: 1.8;
	max-width: 110ch;
  }

  /* Teaching and service section */
  .service-text {
    font-size: 1.5rem;
    color: var(--text-main);
    line-height: 1.2;
    max-width: 100ch;
    margin-bottom: 0rem;
  }

  .service-place {
    font-size: 1.5rem;
    color: var(--text-more-muted);
    line-height: 1.2;
    max-width: 100ch;
    margin-top: 0rem;
  }

  /* Publication Card Grid Layout */
  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pub-card {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1rem;
    background: var(--card-bg);
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .pub-year {
    font-weight: 700;
    color: var(--text-muted);
    font-size: 1.25rem;
    padding-top: 2px;
  }

  .pub-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
  }

  .pub-authors {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin: 0 0 0.25rem 0;
  }

  .author-me{
    font-size: 1.25rem;
    color: var(--extra-accent);
    margin: 0 0 0.25rem 0;
    font-weight: 200;
    text-decoration: none;
  }

  .author-link{
    font-size: 1.25rem;
    color: var(--text-muted);
    margin: 0 0 0.25rem 0;
    text-decoration: none;
  }

  .author-link:hover {
    font-size: 1.25rem;
    color: var(--accent);
    margin: 0 0 0.25rem 0;
    text-decoration: none;
  }

  .pub-venue {
    font-size: 1.25rem;
    font-style: italic;
    color: var(--text-muted);
    margin: 0 0 0.75rem 0;
  }

  .pub-links {
    display: flex;
    gap: 0.75rem;
  }

  .btn-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }

  .btn-link:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  .link {
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }

  .link:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  .hidden-link {
    color: var(--text-main);
    text-decoration: none;
  }

  .hidden-link:hover {
    color: var(--accent-hover);
  }

  /* Footer styling */
  .site-footer {
    margin-top: 5rem; /* Creates a nice gap below your last publication */
    padding-top: 2rem;
    border-top: 1px solid var(--border-color); /* Adds a subtle dividing line */
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-more-muted); /* Uses the same muted color as your links */
  }

  /* Responsive adjustment for small screens */
  @media (max-width: 480px) {
	html {
      font-size: 12px;
    }
    .pub-card {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>